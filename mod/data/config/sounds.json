#collapseopen FLYBY OVERLAY SFX

	# Re-uses vanilla weapon sounds — no redistribution, just resolves against the core install at runtime.
	# Distinct ids per "feel" (heavy ballistic, light ballistic, energy, missile, impact) — fighters pick one in FighterProfile.

	# Volumes are intentionally hot — flyby SFX play against a busy mix (rifle fire,
	# explosions, ambient bed), and we want strafing to read clearly over all of it.
	"marines_flyby_gun_heavy":[
		{"file":"sounds/sfx_wpn_guns/chaingun_fire_01.ogg","pitch":1,"volume":1.0},
		{"file":"sounds/sfx_wpn_guns/heavy_machinegun_fire_01.ogg","pitch":1,"volume":1.0},
	],
	"marines_flyby_gun_light":[
		{"file":"sounds/sfx_wpn_guns/autocannon_fire_01.ogg","pitch":1,"volume":1.0},
	],
	"marines_flyby_gun_energy":[
