#collapseopen VEHICLE ENGINE LOOPS

	# Per-vehicle engine loops borrowed from the base game's sfx_engines/ set — one clip per
	# (tech tier × hull size). The combat engine picks these internally by hull style + size and
	# never registers them as sound ids, so we register our own ids here pointing straight at the
	# core files (resolves against the read-only core install at runtime, same no-redistribution
	# trick as the flyby weapon block below). All clips are mono → positional playLoop.
	#
	# Ids follow marines_engine_<tier>_<size>; EngineVoice.forSpec maps a hull's engine style +
	# hullSize to one of these. Dweller has no fighter-size clip (clamped to frigate in EngineVoice).

	# --- lotek (LOW_TECH) ---
	"marines_engine_lotek_fighter":[   {"file":"sounds/sfx_engines/engine_01_lotek_00_fighter.ogg","pitch":1,"volume":0.8} ],
	"marines_engine_lotek_frigate":[   {"file":"sounds/sfx_engines/engine_01_lotek_01_frigate.ogg","pitch":1,"volume":0.8} ],
	"marines_engine_lotek_destroyer":[ {"file":"sounds/sfx_engines/engine_01_lotek_02_destroyer.ogg","pitch":1,"volume":0.8} ],
	"marines_engine_lotek_cruiser":[   {"file":"sounds/sfx_engines/engine_01_lotek_03_cruiser.ogg","pitch":1,"volume":0.8} ],
	"marines_engine_lotek_capital":[   {"file":"sounds/sfx_engines/engine_01_lotek_04_capital.ogg","pitch":1,"volume":0.8} ],

